DATABASE_URL=postgresql://user:password@localhost:5432/heatsight
SECRET_KEY=change-me-to-a-random-secret-key
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# URL publique HTTPS du backend (Render) — OBLIGATOIRE en prod pour les liens d'abonnement .ics,
# sinon les liens pointent vers localhost. Ex : https://heatsight-api.onrender.com
PUBLIC_API_URL=http://127.0.0.1:8000
# URL publique de l'app frontend (Vercel) — utilisée pour le lien "Voir dans HeatSight" du .ics.
FRONTEND_URL=https://heatsight.vercel.app
